{
  "manifest_version": 3,
  "name": "Brainback: YouTube De-clutter",
  "version": "1.2",
  "description": "An attention firewall for your browser. Removes Shorts and distracting recommendations from YouTube on Desktop and Android.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "brainback-attention-firewall@naman.dev",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
